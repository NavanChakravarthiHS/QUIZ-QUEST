# ============================================
# QUIZ-QUEST Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env files to version control!

# MongoDB Connection
# Get from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# Whitelist all IPs (0.0.0.0/0) for Vercel deployment
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/quiz-platform?retryWrites=true&w=majority

# JWT Secret (Required - must be at least 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Environment
# Use 'development' for local, 'production' for Vercel/deployment
NODE_ENV=development

# Server Port (Local development only, not used on Vercel)
PORT=5005
