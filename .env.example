# MongoDB Connection (Required for Vercel)
# Get from MongoDB Atlas: https://www.mongodb.com/cloud/atlas
# Whitelist all IPs (0.0.0.0/0) for serverless
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/quiz-platform?retryWrites=true&w=majority

# JWT Secret (Required - use 32+ character random string in production)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Environment
NODE_ENV=production

# Port (optional - only for local backend)
PORT=5005
